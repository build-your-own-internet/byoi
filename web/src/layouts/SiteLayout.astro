---
import AppHeaderBar from '../components/AppHeaderBar.astro';
import TableOfContents from '../components/TableOfContents.astro';
import '../styles/globals.css';
import css from './SiteLayout.module.css';

const { currentSlug } = Astro.props;
---
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width" />
  <title>Build Your Own Internet</title>
  <!-- Runtime OIDC config written at deploy time (by-9td.8); 404s harmlessly in dev. -->
  <script is:inline src="/config.js"></script>
</head>
<body>
  <site-layout class={css.class}>
    <AppHeaderBar />
    <main>
      <toc-pane>
        <TableOfContents currentSlug={currentSlug} />
      </toc-pane>
      <content-pane>
        <slot />
      </content-pane>
    </main>
  </site-layout>
</body>
</html>
