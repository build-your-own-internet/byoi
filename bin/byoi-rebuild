#!/bin/bash
# Wrapper script that auto-manages Python virtual environment

set -e

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
VENV_DIR="$SCRIPT_DIR/.venv"
PYTHON_SCRIPT="$SCRIPT_DIR/byoi-rebuild.py"
REQUIREMENTS="$SCRIPT_DIR/requirements.txt"

# Create and setup venv if it doesn't exist
if [ ! -d "$VENV_DIR" ]; then
    echo "First run: setting up Python environment..."
    python3 -m venv "$VENV_DIR"
    "$VENV_DIR/bin/pip" install -q -r "$REQUIREMENTS"
    echo "Setup complete!"
    echo
fi

# Run the Python script with venv Python, passing all arguments
exec "$VENV_DIR/bin/python3" "$PYTHON_SCRIPT" "$@"
